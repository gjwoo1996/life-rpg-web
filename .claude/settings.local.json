{
  "permissions": {
    "allow": [
      "Bash(npx tsc:*)",
      "Bash(npm run:*)",
      "Bash(curl -s -X POST http://localhost:3001/goal-step -H 'Content-Type: application/json' -d '{\"goalId\":\"00000000-0000-0000-0000-000000000000\",\"title\":\"test\"}')",
      "Bash(curl:*)",
      "Bash(pkill -f \"nest start\")",
      "Bash(npx ts-node:*)",
      "Bash(PGPASSWORD=postgres psql:*)",
      "Bash(node:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Read(//home/vscode/**)",
      "Read(//home/vscode/.config/claude/**)",
      "Bash(claude --version)",
      "Bash(git:*)",
      "Bash(bash:*)",
      "Bash(npm install *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty'); [[ \"$f\" == *\"apps/api\"*\".ts\" ]] && (cd /home/vscode/life-rpg-web && npx tsc -p apps/api/tsconfig.json --noEmit 2>&1 | tail -5) || true",
            "timeout": 30,
            "statusMessage": "API 타입 체크 중..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Claude done' | tee /tmp/claude-done.log > /dev/null"
          }
        ]
      }
    ]
  },
  "autoMemoryDirectory": "/home/vscode/life-rpg-web/.claude/memory"
}
